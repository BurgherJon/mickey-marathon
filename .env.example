# Configuration for your agent. Copy to .env (gitignored) and fill in.
# (get_started_linux.sh generates .env for you from your prompts.)

# ==============================================================================
# GCP Projects — there are TWO, with distinct roles
# ==============================================================================
#
# THE FORUM'S PROJECT (= GOOGLE_CLOUD_PROJECT = FORUM_PROJECT_ID)
#   - Where The Forum (middleware) is deployed.
#   - Where THIS AGENT's Reasoning Engine also lives (administratively
#     centralized — every agent shares this project as the deploy target).
#   - The default project for any Google client library running on Vertex AI.
#
# AGENT_PROJECT_ID
#   - This agent's own dedicated project.
#   - Owns: the per-agent service account, all per-agent secrets (platform
#     tokens, MCP keys, etc.), and the ADK staging bucket.
#   - The Reasoning Engine RUNS AS the per-agent SA from this project,
#     authenticating against cross-project IAM bindings provisioned by
#     terraform. So a Google Doc shared with the per-agent SA grants access
#     to THIS agent only, not to every agent in the Forum project.

# Forum's project (deploy target + runtime project from Google libraries'
# perspective). GOOGLE_CLOUD_PROJECT and FORUM_PROJECT_ID are the same value.
GOOGLE_CLOUD_PROJECT=your-forum-project-id
FORUM_PROJECT_ID=your-forum-project-id

# This agent's own project.
AGENT_PROJECT_ID=your-agent-project-id

# Use the global endpoint for model API calls so preview models work.
# agent.py also sets this at import time, so this is mainly for local
# `adk web` runs.
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ==============================================================================
# Models
# ==============================================================================
# Used by agent.py and custom_agents.py. Pick whatever Gemini models suit
# your needs — high-quality for the root agent's reasoning, faster/cheaper
# for sub-agents that do tactical work.
#
# Defaults are Gemini 3 preview models. Gemini 3 emits `thought_signature`
# tokens on tool calls and rejects any follow-up that drops one; the ADK handles
# propagating them for you. (gemini-2.5-flash is slated for shutdown on
# 2026-10-16.)
HIGH_QUALITY_AGENT_MODEL=gemini-3.1-pro-preview
QUICK_AGENT_MODEL=gemini-3-flash-preview

# ==============================================================================
# Agent identity (used by deploy_and_update.sh and register_agent.py)
# ==============================================================================
# Display name MUST match the bot_name in terraform/terraform.tfvars and is
# the Firestore lookup key The Forum uses to find your agent's record.
AGENT_DISPLAY_NAME=My Agent

# Used to construct platform-specific secret names ({BOT_ACCOUNT_ID}-slack-token
# etc.) and to assemble the per-agent SA email. Must match bot_account_id in
# terraform/terraform.tfvars.
BOT_ACCOUNT_ID=my-agent

# ==============================================================================
# The Forum
# ==============================================================================
# Public URL of The Forum's Cloud Run service. Used by the scheduler MCP
# toolset (when enabled) to reach The Forum's hosted MCP endpoint.
FORUM_URL=https://the-forum-XXXXXXXXXX-uc.a.run.app

# ==============================================================================
# Deployment (used by deploy_and_update.sh)
# ==============================================================================
# Absolute paths to the ADK binary and the Python interpreter in the same
# venv. `which adk` and `which python3` in your activated venv will show you.
ADK_BIN=/path/to/your/venv/bin/adk
ADK_PYTHON=/path/to/your/venv/bin/python3

# ==============================================================================
# Persistent memory via Google Docs (recommended; wired up by default)
# ==============================================================================
# get_started_linux.sh prompts for this. The doc must be shared (Editor
# access) with the per-agent SA email
# (BOT_ACCOUNT_ID@AGENT_PROJECT_ID.iam.gserviceaccount.com) — that's the SA
# the Reasoning Engine runs as. Leave blank if you don't want memory; the
# tools in custom_functions.py will raise a clear error at runtime instead.
AGENT_MEMORY_DOC_ID=

# ==============================================================================
# Monitoring (optional but recommended)
# ==============================================================================
# These env vars are safe to leave on. They do NOT trigger the GCP OTel exporter
# crash path — that comes only from the deploy-time --trace_to_cloud /
# --otel_to_cloud flags, which deploy_and_update.sh omits on purpose (see
# requirements.txt). Caveat: ADK-level Cloud Trace spans aren't available until
# the GCP OTel exporters catch up to the OTel SDK the ADK pulls; Cloud Logging
# is unaffected (the platform captures stdout independently), so engine logs
# still work for debugging.
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=TRUE
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=TRUE

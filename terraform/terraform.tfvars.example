# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored to keep your config private.
# (get_started_linux.sh generates this for you from your prompts.)

# ==============================================================================
# GCP Project Configuration
# ==============================================================================
# The project must already exist with billing linked. Create it once via:
#   gcloud projects create YOUR_PROJECT_ID \
#     --name="Your Agent" \
#     --organization=YOUR_ORG_ID
#   gcloud beta billing projects link YOUR_PROJECT_ID --billing-account=YOUR_BILLING_ACCT
project_id = "my-agent-prod"   # Must be globally unique GCP project ID
region     = "us-central1"

# ==============================================================================
# Agent Configuration
# ==============================================================================
bot_name        = "My Agent"   # Display name across all platforms; also the Firestore lookup key
bot_account_id  = "my-agent"   # Lowercase + hyphens, max 30 chars. Used for:
                                #   - service account: my-agent@<project>.iam.gserviceaccount.com
                                #   - secret names: my-agent-slack-token, my-agent-telegram-token, etc.

bot_description = "AI assistant powered by Vertex AI on Comites.ai's The Forum"
bot_avatar_url  = ""           # Optional: for Google Chat avatar

# ==============================================================================
# Google Chat Configuration (only used if Section 3 is uncommented)
# ==============================================================================
chat_credentials_secret_name = "my-agent-chat-credentials"

# ==============================================================================
# The Forum Configuration
# ==============================================================================
# The project where slack-vertex-ai-middleware (The Forum) is deployed.
# Used for cross-project IAM bindings so The Forum's Cloud Run SA can read
# this agent's platform secrets.
forum_project_id = "your-forum-project-id"

# ==============================================================================
# Discord (only if Section 5 is uncommented and you're using Discord)
# ==============================================================================
# From https://discord.com/developers/applications → your app → General Information.
# register_agent.py refuses to write the Discord platform block to Firestore if
# the Discord secret is populated but this value is empty.
discord_application_id = ""

# ==============================================================================
# Post-apply: populate platform secret values
# ==============================================================================
# Terraform creates empty secret CONTAINERS. The actual token values are
# populated post-apply via gcloud (so they never live in terraform state):
#
#   SLACK:        echo -n "xoxb-..." | gcloud secrets versions add \
#                   my-agent-slack-token --data-file=- --project=my-agent-prod
#
#   TELEGRAM:     echo -n "1234567890:ABC..." | gcloud secrets versions add \
#                   my-agent-telegram-token --data-file=- --project=my-agent-prod
#
#   DISCORD:      echo -n "..." | gcloud secrets versions add \
#                   my-agent-discord-token --data-file=- --project=my-agent-prod
#
#   GOOGLE CHAT:  gcloud iam service-accounts keys create key.json \
#                   --iam-account=my-agent@my-agent-prod.iam.gserviceaccount.com \
#                   --project=my-agent-prod && \
#                 gcloud secrets versions add my-agent-chat-credentials \
#                   --data-file=key.json --project=my-agent-prod && \
#                 rm -f key.json
#
# get_started_linux.sh prompts for each token silently and runs these for you.
